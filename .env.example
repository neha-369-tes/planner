# FlowState — Environment Variables
# Copy this to .env and fill in values if needed in future

PORT=3000
HOST=localhost
API_PORT=8787

# Optional MCP bridge URL that can further refine schedule
# Example: MCP_PLANNER_URL=http://localhost:3001/mcp/plan
MCP_PLANNER_URL=

# Optional LLM for natural planner chat assistant
# Example OpenAI-compatible values:
# AI_BASE_URL=https://api.openai.com/v1
# AI_MODEL=gpt-4o-mini
# Or use local Ollama + DeepSeek:
# AI_PROVIDER=ollama
# OLLAMA_BASE_URL=http://127.0.0.1:11434
# OLLAMA_MODEL=deepseek-r1:8b
AI_PROVIDER=ollama
AI_API_KEY=
AI_BASE_URL=https://api.openai.com/v1
AI_MODEL=gpt-4o-mini
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=deepseek-r1:8b
OLLAMA_MAX_TOKENS=220
OLLAMA_TIMEOUT_MS=8000
LLM_TIMEOUT_MS=10000

# Persistent planner memory store for RAG-style retrieval
MEMORY_DB_PATH=./data/planner-memory.json
MAX_MEMORY_EVENTS=2000
